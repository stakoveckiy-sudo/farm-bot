# ============== DATABASE ==============
DATABASE_URL=postgresql+asyncpg://farmstore_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/farmstore_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20

# ============== REDIS ==============
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============== WEBHOOK ==============
WEBHOOK_HOST=farm-store.ru
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_SECRET=your_secret_key_here_change_me_to_random_string

# ============== BOT SERVER ==============
BOT_SERVER_HOST=127.0.0.1
BOT_SERVER_PORT=8080

# ============== STORAGE ==============
STORAGE_PATH=/opt/farm-store/app/storage
IMAGES_PATH=/opt/farm-store/app/storage/images
MAX_IMAGE_SIZE=25000000

# ============== CURRENCY ==============
# Курс обновляется каждый час
RUB_RATE_SOURCE=https://www.cbr-xml-daily.ru/daily_json.js
BYN_RATE_SOURCE=https://www.nbrb.by/api/exrates/rates/840

# ============== PRICING ==============
# Бесплатный план
FREE_SHOWCASES_LIMIT=1
FREE_PRODUCTS_LIMIT=5

# Платный план (месячная подписка)
PRO_SHOWCASES_LIMIT=5
PRO_PRODUCTS_PER_SHOWCASE=100
PRO_PRICE_EUR=30
PRO_PRICE_RUB=2500
PRO_PRICE_BYN=75

# Поднятие в топ (неделя)
TOP_BOOST_PRICE_EUR=2
TOP_BOOST_PRICE_RUB=165
TOP_BOOST_PRICE_BYN=5

# ============== NOTIFICATIONS ==============
# Напоминание об оплате за N дней до истечения (укажите часы в МСК)
SUBSCRIPTION_REMINDER_DAYS=3,2,1
SUBSCRIPTION_REMINDER_HOUR=12

# ============== FEATURES ==============
PASSPORT_CHECK_ENABLED=True
DUPLICATE_CHECK_ENABLED=True
AUTO_MODERATE_PRODUCTS=False

# ============== DEBUG ==============
DEBUG=False
LOG_LEVEL=INFO